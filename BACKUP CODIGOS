@keyframes revealDown {
  from {
    clip-path: inset(0 0 100% 0);
  }
  to {
    clip-path: inset(0 0 0 0);
  }
}

.reveal {
  width: 100%;
  overflow: hidden;
  clip-path: inset(0 0 100% 0);
  animation: revealDown 1.2s ease forwards;
  will-change: clip-path;
}

.delay-1 {
  animation-delay: 0.2s;
}

.delay-2 {
  animation-delay: 0.3s;
}
